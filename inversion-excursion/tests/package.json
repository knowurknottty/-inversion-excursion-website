{
  "name": "inversion-excursion-test-suite",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:integration && npm run test:security",
    "test:unit": "jest --selectProjects unit --coverage",
    "test:integration": "jest --selectProjects integration",
    "test:security": "jest --selectProjects security",
    "test:contracts": "hardhat test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:coverage": "hardhat coverage",
    "contracts:deploy": "hardhat run scripts/deploy.ts",
    "playwright:install": "playwright install",
    "playwright:codegen": "playwright codegen",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run test:contracts"
  },
  "dependencies": {
    "next": "14.x",
    "react": "^18",
    "react-dom": "^18",
    "@prisma/client": "^5.x",
    "@farcaster/auth-kit": "^0.x",
    "@farcaster/frame-sdk": "^0.x",
    "viem": "^2.x",
    "@wagmi/core": "^2.x",
    "siwe": "^2.x",
    "zod": "^3.x",
    "rate-limiter-flexible": "^5.x",
    "ioredis": "^5.x",
    "zustand": "^4.x"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/jest": "^29.x",
    "typescript": "^5",
    "jest": "^29.x",
    "jest-environment-node": "^29.x",
    "ts-jest": "^29.x",
    "@playwright/test": "^1.x",
    "prisma": "^5.x",
    "eslint": "^8",
    "eslint-config-next": "14.x",
    "@nomicfoundation/hardhat-toolbox": "^4.x",
    "@nomicfoundation/hardhat-chai-matchers": "^2.x",
    "hardhat": "^2.x",
    "hardhat-gas-reporter": "^1.x",
    "solidity-coverage": "^0.8.x",
    "chai": "^4.x",
    "@types/chai": "^4.x",
    "prettier": "^3.x",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x"
  }
}
