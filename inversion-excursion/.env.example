# Database
DATABASE_URL="postgresql://user:password@localhost:5432/inversion_excursion?schema=public"

# Redis (optional, for production rate limiting)
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Ethereum
ETHEREUM_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY"

# Farcaster
FARCASTER_HUB_URL="https://hub.pinata.cloud"
FARCASTER_APP_FID="YOUR_APP_FID"
FARCASTER_APP_MNEMONIC="YOUR_MNEMONIC"

# Synsync Integration
SYNSYNC_API_URL="https://api.synsync.pro"
SYNSYNC_API_KEY="your-synsync-api-key"

# Optional: On-chain contracts
NFT_CONTRACT_ADDRESS="0x..."
BATTLE_CONTRACT_ADDRESS="0x..."

# Environment
NODE_ENV="development"
