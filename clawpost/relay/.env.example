# ClawPost Relay Server Environment
# Copy this to .env and fill in your values

# API Key for agent authentication
CLAWPOST_API_KEY=your_secure_random_key_here

# WebSocket secret for extension pairing
CLAWPOST_WS_SECRET=your_websocket_secret_here

# Server port
PORT=4747

# Optional: Google Drive integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4747/auth/google/callback