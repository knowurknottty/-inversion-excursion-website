{
  "manifest_version": 3,
  "name": "KimiClaw Post",
  "version": "1.1.0",
  "description": "Browser-session social posting for KimiClaw agent",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KimiClaw Post"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content/twitter.js"]
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content/instagram.js"]
    },
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content/tiktok.js"]
    }
  ]
}