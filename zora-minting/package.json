{
  "name": "@scrollcards/zora-minting",
  "version": "1.0.0",
  "description": "Zora Coins integration for ScrollCard NFT minting on Base network",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only examples/demo.ts",
    "test": "jest",
    "lint": "eslint sdk/**/*.ts",
    "format": "prettier --write sdk/**/*.ts"
  },
  "keywords": [
    "zora",
    "nft",
    "minting",
