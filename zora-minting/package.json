  "author": "ScrollCards Team",
  "license": "MIT",
  "dependencies": {
    "@zoralabs/protocol-sdk": "^0.11.0",
    "@zoralabs/coins-sdk": "^0.4.6",
    "viem": "^2.0.0",
    "permissionless": "^0.1.0",
    "canvas": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
